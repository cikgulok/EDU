<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>星际盲盒奖励系统 - 完整版</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* 1. 基础环境与背景 */
        body {
            background-color: #020617; /* 极深蓝色 */
            margin: 0;
            overflow-x: hidden;
            font-family: 'Inter', system-ui, sans-serif;
            position: relative;
        }

        /* 2. 背景星空闪烁动画 */
        @keyframes twinkle {
            0%, 100% { opacity: 0.2; transform: scale(1); }
            50% { opacity: 0.8; transform: scale(1.2); }
        }
        .star {
            position: absolute;
            background: white;
            border-radius: 50%;
            pointer-events: none;
            animation: twinkle var(--duration) infinite ease-in-out;
            z-index: 0;
        }

        /* 3. 核心 3D 翻转逻辑 */
        .box-container {
            perspective: 1000px;
        }
        
        .box-inner {
            position: relative;
            width: 100%;
            height: 100%;
            transform-style: preserve-3d;
            transition: transform 0.8s cubic-bezier(0.34, 1.56, 0.64, 1); /* 带有回弹效果的翻转 */
            cursor: pointer;
        }

        .backface-hidden { backface-visibility: hidden; }
        
        .rotate-y-180 { transform: rotateY(180deg); }

        /* 4. 增强特效：科幻扫描线 */
        .scanline {
            width: 100%;
            height: 2px;
            background: rgba(96, 165, 250, 0.2);
            position: absolute;
            top: 0;
            left: 0;
            pointer-events: none;
            animation: scan 3s linear infinite;
            z-index: 5;
        }
        @keyframes scan {
            0% { top: 0%; }
            100% { top: 100%; }
        }

        /* 5. 增强特效：霓虹发光边框 */
        .glow-hover {
            transition: all 0.3s ease;
        }
        .glow-hover:hover {
            box-shadow: 0 0 15px rgba(59, 130, 246, 0.5), inset 0 0 10px rgba(59, 130, 246, 0.2);
            border-color: #3b82f6;
            transform: translateY(-5px);
        }

        /* 隐藏滚动条 */
        ::-webkit-scrollbar {
            display: none;
        }
    </style>
</head>
<body class="text-white min-h-screen relative">

    <!-- 背景星空 -->
    <div id="star-container" class="absolute inset-0 overflow-hidden pointer-events-none"></div>

    <!-- 顶部导航 -->
    <nav class="relative z-10 p-6 flex justify-between items-center bg-slate-900/50 backdrop-blur-md border-b border-slate-800">
        <div class="flex items-center gap-3">
            <div class="text-blue-400 animate-pulse">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-5c1.62-2.2 5-3 5-3"/><path d="M12 15v5s3.03-.55 5-2c2.2-1.62 3-5 3-5"/></svg>
            </div>
            <div>
                <h1 class="text-2xl font-black tracking-tighter bg-gradient-to-r from-blue-400 to-purple-500 bg-clip-text text-transparent uppercase">
                    星际盲盒空间站
                </h1>
                <p class="text-[10px] text-slate-500 font-mono tracking-widest uppercase">Space Rewards Terminal</p>
            </div>
        </div>
        <div class="flex items-center gap-4">
            <button id="mute-btn" class="p-2 hover:bg-slate-800 rounded-full transition-colors text-slate-400">
                <svg id="volume-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/></svg>
            </button>
            <button onclick="initGame()" class="flex items-center gap-2 bg-blue-600 hover:bg-blue-500 px-6 py-2 rounded-full font-bold transition-all transform active:scale-95 shadow-[0_0_20px_rgba(37,99,235,0.4)]">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
                重启系统
            </button>
        </div>
    </nav>

    <!-- 主界面 -->
    <main class="relative z-10 max-w-6xl mx-auto p-8">
        <div class="mb-12 text-center">
            <p class="text-slate-400 text-lg mb-2 italic">完成课业的勇士，请开启你的星际补给包</p>
            <div id="stats" class="inline-block px-4 py-1 rounded-full bg-blue-500/10 border border-blue-500/20 text-xs text-blue-400 font-mono tracking-widest uppercase">
                Captured Pods: 0 / 10
            </div>
        </div>

        <!-- 盲盒网格 -->
        <div id="grid" class="grid grid-cols-2 md:grid-cols-5 gap-8">
            <!-- 由 JS 动态渲染 -->
        </div>

        <footer class="mt-20 py-8 border-t border-slate-900 text-center text-slate-600 text-xs tracking-[0.3em] uppercase">
            <p>© 2024 Starbase Rewards // Galactic Authority // No Alert Policy</p>
        </footer>
    </main>

    <script>
        const REWARDS = [
            { name: "上厕所🚽特权", type: "special", icon: "🚽" },
            { name: "上厕所🚽特权", type: "special", icon: "🚽" },
            { name: "棒棒糖🍭一支", type: "food", icon: "🍭" },
            { name: "一粒糖果🍬", type: "food", icon: "🍬" },
            { name: "一粒糖果🍬", type: "food", icon: "🍬" },
            { name: "两粒糖果🍬🍬", type: "food", icon: "🍬🍬" },
            { name: "一包零食🍿", type: "food", icon: "🍿" },
            { name: "再接再厉👍", type: "empty", icon: "🚀" },
            { name: "王牌🃏", type: "legendary", icon: "🃏" },
            { name: "两粒糖果🍬🍬", type: "food", icon: "🍬" },
        ];

        let isMuted = false;
        let revealedCount = 0;
        let boxes = [];

        // 1. 生成星空
        function createStars() {
            const container = document.getElementById('star-container');
            for (let i = 0; i < 120; i++) {
                const star = document.createElement('div');
                star.className = 'star';
                const size = Math.random() * 2 + 1;
                star.style.width = `${size}px`;
                star.style.height = `${size}px`;
                star.style.top = `${Math.random() * 100}%`;
                star.style.left = `${Math.random() * 100}%`;
                star.style.setProperty('--duration', `${2 + Math.random() * 4}s`);
                container.appendChild(star);
            }
        }

        // 2. Web Audio 音效合成器
        function playSound(type) {
            if (isMuted) return;
            try {
                const ctx = new (window.AudioContext || window.webkitAudioContext)();
                const osc = ctx.createOscillator();
                const gain = ctx.createGain();
                osc.connect(gain);
                gain.connect(ctx.destination);

                if (type === 'click') {
                    osc.frequency.setValueAtTime(440, ctx.currentTime);
                    osc.frequency.exponentialRampToValueAtTime(880, ctx.currentTime + 0.1);
                    gain.gain.setValueAtTime(0.1, ctx.currentTime);
                    gain.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + 0.1);
                    osc.start(); osc.stop(ctx.currentTime + 0.1);
                } else if (type === 'win') {
                    osc.type = 'square';
                    [523.25, 659.25, 783.99].forEach((f, i) => {
                        osc.frequency.setValueAtTime(f, ctx.currentTime + i * 0.1);
                    });
                    gain.gain.setValueAtTime(0.1, ctx.currentTime);
                    gain.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + 0.4);
                    osc.start(); osc.stop(ctx.currentTime + 0.4);
                } else {
                    osc.frequency.setValueAtTime(220, ctx.currentTime);
                    osc.frequency.exponentialRampToValueAtTime(440, ctx.currentTime + 0.2);
                    gain.gain.setValueAtTime(0.1, ctx.currentTime);
                    gain.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + 0.2);
                    osc.start(); osc.stop(ctx.currentTime + 0.2);
                }
            } catch (e) {
                console.log("Audio Error:", e);
            }
        }

        // 3. 初始化游戏界面
        function initGame() {
            const grid = document.getElementById('grid');
            grid.innerHTML = '';
            revealedCount = 0;
            updateStats();
            
            // 洗牌算法打乱奖励
            boxes = [...REWARDS].sort(() => Math.random() - 0.5);

            boxes.forEach((reward, index) => {
                const boxContainer = document.createElement('div');
                boxContainer.className = 'box-container h-52 relative';
                
                const inner = document.createElement('div');
                inner.className = 'box-inner relative w-full h-full preserve-3d';
                inner.onclick = () => openBox(inner, index, reward);

                // 正面 (Closed State)
                const front = document.createElement('div');
                front.className = 'absolute inset-0 backface-hidden rounded-2xl border border-slate-700 bg-slate-900/80 flex flex-col items-center justify-center gap-3 glow-hover overflow-hidden';
                front.innerHTML = `
                    <div class="scanline"></div>
                    <div class="w-16 h-16 rounded-full flex items-center justify-center bg-slate-800 border border-slate-700 shadow-inner group-hover:scale-110 transition-transform">
                        <svg class="text-blue-400/80" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
                    </div>
                    <span class="text-[10px] font-mono text-slate-500 tracking-[0.3em]">POD-${String(index + 1).padStart(2, '0')}</span>
                `;

                // 背面 (Opened State)
                const back = document.createElement('div');
                let styleClasses = "from-slate-800 to-slate-900 border-slate-700";
                let textClass = "text-white";
                
                if (reward.type === 'legendary') {
                    styleClasses = "from-yellow-500/20 to-orange-600/20 border-yellow-500 shadow-[0_0_30px_rgba(234,179,8,0.2)]";
                    textClass = "text-yellow-400";
                } else if (reward.type === 'special') {
                    styleClasses = "from-purple-500/20 to-pink-600/20 border-purple-500";
                    textClass = "text-purple-400";
                } else if (reward.type === 'empty') {
                    styleClasses = "from-slate-700/50 to-slate-800/50 border-slate-600";
                    textClass = "text-slate-400";
                }
                
                back.className = `absolute inset-0 rotate-y-180 backface-hidden rounded-2xl border-2 bg-gradient-to-br flex flex-col items-center justify-center p-4 text-center ${styleClasses}`;
                back.innerHTML = `
                    <div class="text-5xl mb-3 drop-shadow-lg">${reward.icon}</div>
                    <div class="font-bold text-sm tracking-tight ${textClass}">${reward.name}</div>
                    ${reward.type === 'legendary' ? '<div class="mt-3 text-[9px] bg-yellow-500 text-black px-3 py-1 rounded-full font-black tracking-widest uppercase">Unlocked</div>' : ''}
                `;

                inner.appendChild(front);
                inner.appendChild(back);
                boxContainer.appendChild(inner);
                grid.appendChild(boxContainer);
            });
        }

        function openBox(element, index, reward) {
            if (element.classList.contains('rotate-y-180')) return;

            // 触发翻转
            playSound('click');
            element.classList.add('rotate-y-180');
            revealedCount++;
            updateStats();

            // 翻转到一半时播放对应音效
            setTimeout(() => {
                if (reward.type === 'legendary' || reward.type === 'special') {
                    playSound('win');
                } else {
                    playSound('reveal');
                }
            }, 150);
        }

        function updateStats() {
            document.getElementById('stats').innerText = `Captured Pods: ${revealedCount} / 10`;
        }

        // 静音逻辑
        document.getElementById('mute-btn').onclick = function() {
            isMuted = !isMuted;
            const icon = document.getElementById('volume-icon');
            icon.style.opacity = isMuted ? '0.3' : '1';
        };

        // 页面加载后启动
        window.onload = () => {
            createStars();
            initGame();
        };
    </script>
</body>
</html>
